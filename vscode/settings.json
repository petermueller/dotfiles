{
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    "editor.tabSize": 2,
    "workbench.iconTheme": "file-icons",
    "window.title": "${dirty}${activeEditorShort}${separator}${activeFolderMedium} [${rootName}]",
    "files.watcherExclude": {
        "**/_build/**": true,
        "**/.elixir_ls/**": true
    },
    "files.exclude": {
        "**/_build": true,
        "**/.elixir_ls": true
    },
    "[markdown]": {},
    "elixirLS.mixEnv": "dev",
    "[elixir]": {
        "editor.defaultFormatter": "JakeBecker.elixir-ls",
        "editor.rulers": [
            98
        ]
    },
    "markdown.extension.toc.githubCompatibility": true,
    "terminal.integrated.profiles.osx": {
        "bash": {
            "path": "bash",
            "icon": "terminal-bash"
        },
        "zsh (login)": {
            "path": "zsh"
        }
    },
    "terminal.integrated.defaultProfile.osx": "zsh (login)",
    "editor.largeFileOptimizations": false,
    "files.associations": {
        "Jenkinsfile_build": "jenkinsfile",
        "Jenkinsfile_deploy": "jenkinsfile"
    },
    "workbench.colorTheme": "Gruvbox Light (Medium)",
    "editor.fontLigatures": false,
    "editor.formatOnSave": true,
    "editor.wordSeparators": "`~!@#$%^&*()=+[{]}\\|;:'\",.<>?",
    "workbench.startupEditor": "newUntitledFile",
    "elixirLS.dialyzerFormat": "dialyxir_long",
    "editor.minimap.enabled": false,
    "emmet.includeLanguages": {
        "html-eex": "html"
    },
    "diffEditor.ignoreTrimWhitespace": false,
    "gitlens.codeLens.scopes": [
        "document",
        "containers"
    ],
}
