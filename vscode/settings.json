{
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    "editor.tabSize": 2,
    "workbench.iconTheme": "file-icons",
    "window.title": "${dirty}${activeEditorShort}${separator}${activeFolderMedium} [${rootName}]",
    "files.watcherExclude": {
        "**/_build/**": true,
        "**/.elixir_ls/**": true,
        "**/.yarn/**": true
    },
    "files.exclude": {
        "**/_build": true,
        "**/.elixir_ls": true,
        "**/.yarn": true
    },
    "[markdown]": {},
    "elixirLS.mixEnv": "dev",
    "[elixir]": {
        "editor.defaultFormatter": "JakeBecker.elixir-ls",
        "editor.rulers": [
            98
        ]
    },
    "markdown.extension.toc.githubCompatibility": true,
    "terminal.external.osxExec": "iTerm.app",
    "terminal.integrated.enableBold": true,
    "terminal.integrated.rightClickCopyPaste": true,
    "terminal.integrated.fontFamily": "SauceCodeProNerdFontCompleteM-Regular",
    "terminal.integrated.profiles.osx": {
        "bash": {
            "path": "bash",
            "icon": "terminal-bash"
        },
        "zsh (login)": {
            "path": "zsh"
        }
    },
    "terminal.integrated.defaultProfile.osx": "zsh (login)",
    "editor.largeFileOptimizations": false,
    "files.associations": {
        "Jenkinsfile_build": "jenkinsfile",
        "Jenkinsfile_deploy": "jenkinsfile"
    },
    "workbench.colorTheme": "Gruvbox Light (Soft)",
    "editor.bracketPairColorization.enabled": true,
    "editor.fontLigatures": false,
    "editor.formatOnSave": true,
    "editor.wordSeparators": "`~!@#$%^&*()=+[{]}\\|;:'\",.<>?",
    "workbench.startupEditor": "newUntitledFile",
    "editor.minimap.enabled": false,
    "emmet.includeLanguages": {
        "html-eex": "html",
        "phoenix-heex": "html"
    },
    "diffEditor.ignoreTrimWhitespace": false,
    "gitlens.codeLens.scopes": [
        "document",
        "containers"
    ],
    "editor.inlineSuggest.enabled": true,
    "github.copilot.enable": {
        "*": true,
        "yaml": false,
        "plaintext": false,
        "markdown": true,
        "elixir": false,
        "ruby": false
    },
    "editor.multiCursorModifier": "ctrlCmd",
    "tailwindCSS.includeLanguages": {
        "Elixir HTML (heex)": "heex"
    },
    "liveshare.presence": true,
    "window.zoomLevel": 1
}
